# === REQUIRED ===

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# NewsAPI (get free key at https://newsapi.org)
NEWSAPI_KEY=

# === OPTIONAL ===

# Euri API — free 200K tokens/day (https://euron.one → Dashboard → API Key)
# Used for AI-powered ranking & summarization. Without it, falls back to keyword scoring.
EURI_API_KEY=

# Tavily Search — AI search (https://tavily.com, 1000 free requests/month)
# Extra news source. Not required — NewsAPI + RSS work fine without it.
TAVILY_API_KEY=

# OpenRouter — fallback LLM provider (https://openrouter.ai)
OPENROUTER_API_KEY=
