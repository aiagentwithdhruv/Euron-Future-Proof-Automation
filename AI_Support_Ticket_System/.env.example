# === REQUIRED: LLM (Euri free tier — 200K tokens/day at euron.one) ===
EURI_API_KEY=

# === Optional LLM fallbacks ===
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# === Inbox (IMAP) ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=                 # Gmail App Password, NOT real password

# === Ticket Store ===
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Tickets

# === Email Out ===
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# === Notifications ===
SLACK_WEBHOOK_URL=

# === Knowledge ===
KNOWLEDGE_BASE_PATH=./knowledge/

# === Safety ===
GUARDRAIL_STRICT=true
AUTO_SEND_ON_APPROVAL=true
