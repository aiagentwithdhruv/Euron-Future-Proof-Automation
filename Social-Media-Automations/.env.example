# === LLM Provider (for AI content generation) ===
# At least one required for AI mode

# Euri (FREE — 200K tokens/day, get from euron.one -> Dashboard -> API Key)
EURI_API_KEY=

# OpenRouter (300+ models — get from openrouter.ai)
OPENROUTER_API_KEY=

# === LinkedIn API ===
# Create app at: https://www.linkedin.com/developers/apps
# Required scopes: w_member_social, r_basicprofile
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# === X / Twitter API ===
# Create app at: https://developer.x.com/en/portal/dashboard
# Free tier: 1,500 tweets/month
# Required: OAuth 1.0a User Context
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# === Instagram (via Meta Graph API) ===
# Create app at: https://developers.facebook.com/apps/
# Requires: Facebook Business Page + Instagram Professional Account linked
# Permissions: instagram_basic, instagram_content_publish, pages_read_engagement
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# === YouTube (via Google API) ===
# Create project at: https://console.cloud.google.com/
# Enable: YouTube Data API v3
# Create OAuth 2.0 credentials (Desktop App type)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
