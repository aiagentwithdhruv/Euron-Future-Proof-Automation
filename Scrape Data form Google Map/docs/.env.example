# ============================================
# Google Maps Lead Scraper — API Keys
# ============================================
# Copy this file to the project root as .env:
#   cp docs/.env.example .env
#
# NEVER commit the .env file to git!
# ============================================

# ── Apify (Primary Scraper) ──────────────────
# Sign up: https://apify.com
# Free: $5/mo credits (~1,000 results)
APIFY_API_TOKEN=

# ── Outscraper (Fallback Scraper) ────────────
# Sign up: https://app.outscraper.com
# Free: 500 records (one-time)
OUTSCRAPER_API_KEY=

# ── Hunter.io (Email Enrichment) ��────────────
# Sign up: https://hunter.io
# Free: 25 searches/month
HUNTER_API_KEY=

# ── Google Sheets (Optional Export) ──────────
# Create service account: https://console.cloud.google.com
# Put JSON key file in credentials/service_account.json
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/service_account.json
GOOGLE_SHEETS_SPREADSHEET_NAME=Google Maps Leads

# ── Defaults ────────���────────────────────────
DEFAULT_LEAD_LIMIT=50
DEFAULT_LANGUAGE=en
