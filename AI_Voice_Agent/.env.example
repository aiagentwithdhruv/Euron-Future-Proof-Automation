# === Runtime ===
ENVIRONMENT=dev
LOG_LEVEL=INFO
API_KEY=                          # shared secret the voice platform sends on every tool call

# === Voice Platform (pick one; Vapi is the default) ===
VOICE_PLATFORM=vapi
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=             # required for outbound
VAPI_API_BASE=https://api.vapi.ai

# Alternatives (unused unless you switch VOICE_PLATFORM)
BLAND_API_KEY=
RETELL_API_KEY=

# === Business Context (interpolated into receptionist prompt) ===
BUSINESS_NAME=Acme Business
BUSINESS_HOURS=Mon-Fri 9am-6pm, Sat 10am-2pm
BUSINESS_SERVICES=consultations, follow-ups
BUSINESS_TIMEZONE=America/Los_Angeles
RECORDING_ENABLED=true
HUMAN_HANDOFF_NUMBER=             # E.164, e.g. +15551234567 — leave empty = offer callback only

# === LLM (Euri — free 200k tokens/day; OpenAI-compatible) ===
EURI_API_KEY=
EURI_BASE_URL=https://api.euron.one/api/v1/euri
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o

# === Calendar ===
GOOGLE_CALENDAR_ID=
# Service account JSON: path, raw JSON string, or base64-encoded JSON
GOOGLE_SERVICE_ACCOUNT_JSON=
DEFAULT_SLOT_MINUTES=30

# === SMS (Twilio) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# === Email (Resend) ===
RESEND_API_KEY=
EMAIL_FROM=

# === CRM / Store (Supabase) ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === Compliance Gates for Outbound ===
OUTBOUND_WINDOW_START=9
OUTBOUND_WINDOW_END=19
MAX_OUTBOUND_ATTEMPTS=3
