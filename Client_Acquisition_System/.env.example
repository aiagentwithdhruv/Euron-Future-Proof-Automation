# ─── Scrape ───────────────────────────────────────────────────────
APIFY_API_TOKEN=
OUTSCRAPER_API_KEY=

# ─── Enrich ───────────────────────────────────────────────────────
HUNTER_API_KEY=
APOLLO_API_KEY=

# ─── LLM (primary: Euri — free 200K tokens/day) ───────────────────
EURI_API_KEY=
EURI_BASE_URL=https://api.euron.one/api/v1/euri
EURI_MODEL_QUALIFY=gpt-4o-mini
EURI_MODEL_PERSONALIZE=gpt-4o
# Optional fallbacks
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ─── Outreach (Email) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=hello@yourdomain.com
EMAIL_FROM_NAME=Your Name
EMAIL_UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
EMAIL_POSTAL_ADDRESS=Your Company, Street, City, Country
EMAIL_REPLY_TO=
# Rate limits
EMAIL_DAILY_LIMIT=50
EMAIL_PER_PROSPECT_COOLDOWN_DAYS=3

# ─── LinkedIn (DRAFT ONLY — human sends) ──────────────────────────
# LinkedIn DMs are NOT automated. We only generate drafts.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ─── Calendar ─────────────────────────────────────────────────────
CALCOM_API_KEY=
BOOKING_URL=https://cal.com/yourhandle/discovery

# ─── State (optional Airtable mirror) ─────────────────────────────
# Leave blank to use local JSON state store.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PIPELINE_TABLE=Pipeline

# ─── Notify ───────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── ICP / Offer ──────────────────────────────────────────────────
ICP_CONFIG=./config/icp.yaml
OFFER_CONFIG=./config/offer.yaml

# ─── Safety ───────────────────────────────────────────────────────
# If set to "true", all tools refuse to make real outbound sends.
DRY_RUN_DEFAULT=true
